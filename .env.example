# Core runtime
QA_RUNNER_PLAYWRIGHT_EXECUTION_MODE=mcp
QA_RUNNER_BASE_URL=http://127.0.0.1:3000
QA_RUNNER_CORS_ORIGIN=http://localhost:2173

# Playwright project/runtime
QA_RUNNER_PLAYWRIGHT_PROJECT_DIR=e2e/ui
QA_RUNNER_PLAYWRIGHT_UI_HOST=127.0.0.1
QA_RUNNER_PLAYWRIGHT_UI_PORT=9323
QA_RUNNER_MANUAL_AI_STEP_TIMEOUT_MS=8000

# MCP transport/runtime
QA_RUNNER_PLAYWRIGHT_MCP_TRANSPORT=stdio
QA_RUNNER_PLAYWRIGHT_MCP_URL=http://localhost:8931/mcp
QA_RUNNER_PLAYWRIGHT_MCP_COMMAND=npx
QA_RUNNER_PLAYWRIGHT_MCP_ARGS=-y @playwright/mcp@0.0.70 --browser chromium
QA_RUNNER_PLAYWRIGHT_MCP_TIMEOUT_MS=30000

# Manual checklist credentials (used by "Fill ...: E2E_EMAIL/E2E_PASSWORD")
E2E_EMAIL=
E2E_PASSWORD=

# Optional integrations
QA_RUNNER_GITHUB_TOKEN=
QA_RUNNER_AI_PROVIDER=agent
QA_RUNNER_AI_FALLBACK_CHAIN=agent,local,remote
QA_RUNNER_AI_ALLOWED_PROVIDERS=agent,local,remote
