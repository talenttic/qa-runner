{
  "name": "qa-runner-vscode",
  "version": "0.1.0",
  "private": true,
  "main": "dist/extension.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/vscode": "^1.89.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "qaRunner.sendEvent",
        "title": "QA Runner: Send QA Event"
      }
    ]
  },
  "activationEvents": [
    "onCommand:qaRunner.sendEvent"
  ]
}
